# ─── SERVER ───────────────────────────────────────────────────────────────────
# PORT is injected automatically by Hostinger hPanel — do NOT set it manually
NODE_ENV=production

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── DATABASE (MySQL — Hostinger Business provides MySQL, NOT PostgreSQL) ──────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Find credentials in Hostinger hPanel → Databases → MySQL Databases
DATABASE_URL="mysql://db_user:db_password@localhost:3306/db_name"

# ─── FIREBASE ADMIN SDK ───────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── FIREBASE CLOUD MESSAGING ─────────────────────────────────────────────────
FCM_SERVER_KEY=your_fcm_server_key

# ─── EMAIL (Nodemailer — Hostinger) ──────────────────────────────────────────
# Create the email first: hPanel → Emails → Email Accounts → Create
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_hostinger_email_password
EMAIL_FROM=noreply@yourdomain.com

# ─── GOOGLE MAPS ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── WEATHER (Open-Meteo — free, no key required) ─────────────────────────────
WEATHER_BASE_URL=https://api.open-meteo.com/v1
WEATHER_TIMEZONE=Asia/Manila

# ─── OPENAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your admin panel domain)
# Example: https://admin.yourdomain.com,https://yourdomain.com
CORS_ORIGINS=https://admin.yourdomain.com
